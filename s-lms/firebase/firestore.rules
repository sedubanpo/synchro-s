rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.role
        : '';
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.role == 'ADMIN' ||
        request.auth.token.isAdmin == true ||
        currentUserRole() == 'ADMIN'
      );
    }

    function isStaffOrAdmin() {
      return isAdmin() || (
        signedIn() && (
          request.auth.token.role == 'STAFF' ||
          request.auth.token.role == 'DESK' ||
          currentUserRole() == 'STAFF' ||
          currentUserRole() == 'DESK'
        )
      );
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasStudentAccess(studentId) {
      return isAdmin() || (
        signedIn() &&
        request.auth.token.allowedStudentIds is list &&
        studentId in request.auth.token.allowedStudentIds
      );
    }

    function hasStudentPermissionDoc(studentId) {
      return signedIn() && (
        exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.loginId is string &&
          currentUserDoc().data.loginId != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.loginId))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.instructorId is string &&
          currentUserDoc().data.instructorId != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.instructorId))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.teacherId is string &&
          currentUserDoc().data.teacherId != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.teacherId))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.phone is string &&
          currentUserDoc().data.phone != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.phone))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.phoneNumber is string &&
          currentUserDoc().data.phoneNumber != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.phoneNumber))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.mobile is string &&
          currentUserDoc().data.mobile != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.mobile))
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          currentUserDoc().data.mobilePhone is string &&
          currentUserDoc().data.mobilePhone != '' &&
          exists(/databases/$(database)/documents/studentPermissions/$(studentId + '__' + currentUserDoc().data.mobilePhone))
        )
      );
    }

    function canUseMonthlyReport(studentId) {
      return isStaffOrAdmin() || hasStudentAccess(studentId) || hasStudentPermissionDoc(studentId);
    }

    function currentUserFieldMatches(value, field) {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        currentUserDoc().data[field] is string &&
        currentUserDoc().data[field] != '' &&
        currentUserDoc().data[field] == value;
    }

    function ownsMonthlyReportData(data) {
      return signedIn() && (
        data.authorId == request.auth.uid ||
        data.createdById == request.auth.uid ||
        currentUserFieldMatches(data.authorId, 'loginId') ||
        currentUserFieldMatches(data.authorId, 'instructorId') ||
        currentUserFieldMatches(data.authorId, 'teacherId') ||
        currentUserFieldMatches(data.authorId, 'phone') ||
        currentUserFieldMatches(data.authorId, 'phoneNumber') ||
        currentUserFieldMatches(data.authorId, 'mobile') ||
        currentUserFieldMatches(data.authorId, 'mobilePhone') ||
        currentUserFieldMatches(data.authorId, 'email') ||
        currentUserFieldMatches(data.authorId, 'name') ||
        currentUserFieldMatches(data.createdById, 'loginId') ||
        currentUserFieldMatches(data.createdById, 'instructorId') ||
        currentUserFieldMatches(data.createdById, 'teacherId') ||
        currentUserFieldMatches(data.createdById, 'phone') ||
        currentUserFieldMatches(data.createdById, 'phoneNumber') ||
        currentUserFieldMatches(data.createdById, 'mobile') ||
        currentUserFieldMatches(data.createdById, 'mobilePhone') ||
        currentUserFieldMatches(data.createdById, 'email') ||
        currentUserFieldMatches(data.createdById, 'name')
      );
    }

    match /loginAliases/{aliasHash} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /userProfiles/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /userAppAccess/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /accountManagementRequests/{requestId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /accountManagementAuditLogs/{auditId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /studentGrades/{gradeId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studentGradeHistories/{historyId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studentLogs/{logId} {
      allow get, list: if signedIn();
      allow create: if signedIn()
        && (
          request.resource.data.createdById == request.auth.uid ||
          isAdmin() ||
          (
            request.resource.data.restoredFromRowNumber is string &&
            request.resource.data.reactionsByUser is map
          )
        )
        && request.resource.data.studentId is string
        && request.resource.data.content is string;
      allow update: if signedIn()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reactions',
            'reactionsJson',
            'reactionsByUser',
            'reactionsUpdatedAt'
          ]) ||
          (
            (isAdmin() || resource.data.createdById == request.auth.uid)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'content',
              'tags',
              'tagsText',
              'updatedAt',
              'updatedAtMs',
              'updatedById',
              'updatedByName'
            ])
            && request.resource.data.content is string
            && request.resource.data.updatedById == request.auth.uid
          )
        );
      allow delete: if signedIn()
        && (isAdmin() || resource.data.createdById == request.auth.uid);
    }

    match /dashboardSnapshots/{snapshotId} {
      allow get: if (snapshotId == 'GLOBAL_NOTICE' && signedIn()) ||
        isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow list: if false;
      allow create, update: if signedIn()
        && (
          (
            snapshotId == 'GLOBAL_NOTICE' &&
            isAdmin() &&
            request.resource.data.type == 'globalNotice' &&
            request.resource.data.content is string
          ) ||
          (
            request.resource.data.userId == request.auth.uid &&
            request.resource.data.snapshotJson is string
          )
        );
      allow delete: if false;
    }

    match /permissionRequests/{requestId} {
      allow get: if isAdmin() || (
        signedIn() &&
        (resource.data.instructorId == request.auth.uid || resource.data.instructorUid == request.auth.uid)
      );
      allow list: if signedIn();
      allow create: if signedIn() && (
        request.resource.data.instructorId == request.auth.uid ||
        request.resource.data.instructorUid == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /studentPermissions/{documentId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studentHomerooms/{documentId} {
      allow get, list: if isStaffOrAdmin();
      allow create, update, delete: if isStaffOrAdmin();
    }

    match /studentMonthlyReports/{reportId} {
      allow get, list: if canUseMonthlyReport(resource.data.studentId);
      allow create: if signedIn()
        && canUseMonthlyReport(request.resource.data.studentId)
        && request.resource.data.studentId is string
        && request.resource.data.month is string
        && request.resource.data.subject in ['국어', '수학', '영어', '과학', '사회']
        && request.resource.data.updatedById == request.auth.uid
        && (isAdmin() || ownsMonthlyReportData(request.resource.data));
      allow update: if signedIn()
        && canUseMonthlyReport(request.resource.data.studentId)
        && request.resource.data.studentId is string
        && request.resource.data.month is string
        && request.resource.data.subject in ['국어', '수학', '영어', '과학', '사회']
        && request.resource.data.updatedById == request.auth.uid
        && resource.data.studentId == request.resource.data.studentId
        && (
          isAdmin() ||
          (
            ownsMonthlyReportData(resource.data) &&
            ownsMonthlyReportData(request.resource.data) &&
            request.resource.data.authorId == resource.data.authorId
          )
        );
      allow delete: if signedIn()
        && canUseMonthlyReport(resource.data.studentId)
        && (
          isAdmin() ||
          ownsMonthlyReportData(resource.data)
        );
    }

    match /events/{eventId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isStaffOrAdmin();
    }

    match /jikboSubjects/{subjectId} {
      allow get, list: if isStaffOrAdmin();
      allow create, update, delete: if isStaffOrAdmin();
    }

    match /jikboStudentOverrides/{overrideId} {
      allow get, list: if isStaffOrAdmin();
      allow create, update, delete: if isStaffOrAdmin();
    }

    match /jikboStatuses/{statusId} {
      allow get, list: if isStaffOrAdmin();
      allow create, update, delete: if isStaffOrAdmin();
    }

    match /materials/{materialId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /materialOpenLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /materialSettings/{settingId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /gradeSettings/{settingId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studentCards/{studentId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /userStudentAccess/{documentId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
